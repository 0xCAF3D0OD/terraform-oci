#!/Users/dino/.venv/bin/python

from __future__ import annotations

import sys
import oci

from classes import ConfigState
from dotenv import load_dotenv

from governance_resources.compartment_handler import compartment_handler, compartment_selection

from management_resources.groupes_handler import groups_handler
from management_resources.users_handler import users_handler
from management_resources.policy_handler import policy_handler

from utils.config import YELLOW, RESET
from utils.inquire_handler import (
    inquire_display_user_actions,
    inquirer_oci_users
)

load_dotenv()

def validate_permissions(resource, method):
    try:
        response = method()
        print(f"✅ Permissions verified: User can list {resource}.")
        return True, response
    except oci.exceptions.ServiceError as e:
        if e.status == 403:
            print(f"❌ {resource} Access Denied: User does not have permissions.")
        else:
            print(f"⚠️ OCI Service Error: {e.message} for {resource}")
        return False, None
    except Exception as e:
        print(f"❌ Connection error for {resource}: {e}")
        return False, None


def check_users_permissions(
        identity_client,
        identity_domains_client,
        tenancy_id,
        config_class: ConfigState
) -> None:

    print(f'\n🔍 {YELLOW}Checking IAM Permissions...{RESET} {config_class.target_user_credentials["user_name"]}\n')

    # 1. Test des compartiments (on garde l'ID racine par défaut)
    target_id = tenancy_id
    c_status, c_response = validate_permissions(
        "Compartments",
        lambda: identity_client.list_compartments(compartment_id=tenancy_id, limit=1))

    # On met à jour l'ID cible seulement si on a reçu des données
    if c_status and c_response and c_response.data:
        target_id = c_response.data[0].id

    # 2. Exécution des autres tests
    p_status, p_response = validate_permissions(
        "Policies", lambda: identity_client.list_policies(compartment_id=target_id, limit=1))

    g_status, g_response = validate_permissions(
        "Groups", lambda: identity_domains_client.list_groups())

    u_status, u_response = validate_permissions(
        "Users", lambda: identity_domains_client.list_users(limit=1))

    # 3. Construction sécurisée du dictionnaire de réponses
    # On utilise .data seulement si l'objet existe, sinon on met une liste vide []
    responses = {
        "compartments": {"status": c_status, "data": c_response.data if c_status and c_response else []},
        "policies": {"status": p_status, "data": p_response.data if p_status and p_response else []},
        "groups": {"status": g_status, "data": g_response.data if g_status and g_response else []},
        "users": {"status": u_status, "data": u_response.data if u_status and u_response else []}
    }
    config_class.iam_user_resources_access = responses
    # all_passed = all([c_status, p_status, g_status, u_status])

def main():
    try:
        config_class = ConfigState()
        while True:
            user_action = inquire_display_user_actions()
            if len(user_action) == 0:
                print("-- Exit process... ---")
                sys.exit(0)
            else:
                # Config file content retrieval
                config_file = oci.config.from_file("~/.oci/config")

                # Oci user selection in terminal
                selected_user_credentials, identity_domains_client = inquirer_oci_users(config_file, config_class)

                # User credentials in config file retrieval
                config_class.config_file_entries = oci.config.from_file(
                    "~/.oci/config",
                    config_class.get_username()
                )
                # Initialize Identity client to handle OCI API calls for the selected user.
                identity_client = oci.identity.IdentityClient(config_class.config_file_entries)

                #Did the user have permission for doing the further commands
                check_users_permissions(
                    identity_client,
                    identity_domains_client,
                    config_class.get_tenancy(),
                    config_class
                )

                if "new compartment" in user_action and config_class.get_compartment_status() == True:
                    compartment_handler(identity_client, config_class)
                elif "new group" in user_action:
                    compartment_selection(identity_client, config_class)
                    groups_handler(identity_client, config_class)
                elif "new user" in user_action:
                    compartment_selection(identity_client, config_class)
                    users_handler(identity_domains_client, identity_client, config_class)
                elif "new policy" in user_action and config_class.get_policies_status() == True:
                    compartment_selection(identity_client, config_class)
                    policy_handler(identity_client, config_class)
                break
    except oci.exceptions.ConfigFileNotFound as e:
        print(f'OCI ERROR Config file not found: {e}')
    except oci.exceptions.ClientError as e:
        print(f"OCI ERROR client error: {e}")
    except oci.exceptions.ConnectTimeout as e:
        print(f"OCI ERROR timeout: {e}")
    except Exception as e:
        print(f"Error in main methode: {e}")

if __name__ == "__main__":
    main()